# Firebase config — public by design (client-side app, public repo).
# Security lives entirely in firestore.rules / database.rules.json.
# No .env at all -> the app runs in localStorage mode.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# Realtime Database (presence)
VITE_FIREBASE_DATABASE_URL=

# Set to "local" to FORCE localStorage mode even with the config above.
# `npm run dev:local` does this for you — safe sandbox, never touches Firebase.
# VITE_BACKEND=local
